{
  "name": "@xb/types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".":           { "types": "./dist/index.d.ts",      "import": "./dist/index.js" },
    "./brand":     { "types": "./dist/brand.d.ts",      "import": "./dist/brand.js" },
    "./ids":       { "types": "./dist/ids.d.ts",        "import": "./dist/ids.js" },
    "./money":     { "types": "./dist/money.d.ts",      "import": "./dist/money.js" },
    "./actor":     { "types": "./dist/actor.d.ts",      "import": "./dist/actor.js" },
    "./permission":{ "types": "./dist/permission.d.ts", "import": "./dist/permission.js" },
    "./module":    { "types": "./dist/module.d.ts",     "import": "./dist/module.js" },
    "./api":       { "types": "./dist/api.d.ts",        "import": "./dist/api.js" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.5.4"
  }
}
