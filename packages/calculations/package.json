{
  "name": "@xb/calculations",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".":       { "types": "./dist/index.d.ts",  "import": "./dist/index.js" },
    "./money": { "types": "./dist/money.d.ts",  "import": "./dist/money.js" },
    "./engine":{ "types": "./dist/engine.d.ts", "import": "./dist/engine.js" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@xb/types": "workspace:*",
    "decimal.js": "^10.4.3"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3"
  }
}
