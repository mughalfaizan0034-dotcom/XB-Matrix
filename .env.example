# =============================================================================
# xB Matrix — Environment Variables (root .env.example)
# =============================================================================
# Copy this file to .env.local for local development.
# In Cloud Run, all values come from Secret Manager.
# Never commit real values.

# --- Node ---
NODE_ENV=development

# --- API ---
API_PORT=4000
API_HOST=0.0.0.0
API_LOG_LEVEL=info
API_BASE_URL=http://localhost:4000

# --- Web ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=xB Matrix

# --- PostgreSQL (Cloud SQL) ---
# For Cloud SQL via socket: postgresql://USER:PASS@/DB?host=/cloudsql/PROJECT:REGION:INSTANCE
# For local: postgresql://USER:PASS@localhost:5432/xbmatrix
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/xbmatrix
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Google Cloud ---
GCP_PROJECT_ID=
GCP_REGION=
GCP_RUNTIME_SERVICE_ACCOUNT=
GCS_UPLOADS_BUCKET=
GCS_REPORTS_BUCKET=
BIGQUERY_DATASET=xbmatrixbq
CLOUD_TASKS_QUEUE=
CLOUD_TASKS_LOCATION=

# --- Auth ---
JWT_SECRET=change-me-locally
JWT_ISSUER=xb-matrix
JWT_AUDIENCE=xb-matrix-api
SESSION_COOKIE_NAME=xbm_session
SESSION_COOKIE_DOMAIN=

# --- AI Providers (free tier first) ---
AI_DEFAULT_PROVIDER=groq
GROQ_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# --- Observability ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
