{
  "name": "@xb/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "tsx src/db/migrate.ts up",
    "db:rollback": "tsx src/db/migrate.ts down",
    "db:status": "tsx src/db/migrate.ts status",
    "seed:admin": "tsx src/cli/seed-admin.ts",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/sensible": "^6.0.4",
    "@xb/ai": "workspace:*",
    "@xb/auth": "workspace:*",
    "@xb/calculations": "workspace:*",
    "@xb/config": "workspace:*",
    "@xb/types": "workspace:*",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "ulid": "^3.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.10",
    "pino-pretty": "^13.1.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  }
}
